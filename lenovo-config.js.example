/**
 * 联想个人云配置文件示例
 * 
 * 使用说明：
 * 1. 将此文件重命名为 lenovo-config.js
 * 2. 填写您的联想个人云信息
 * 3. 比GitHub配置简单得多！
 */

window.LENOVO_CLOUD_CONFIG = {
    enabled: true,                              // 设置为true启用自动同步
    url: 'http://192.168.1.100:5005',          // 联想个人云WebDAV地址
    username: 'planSync',                       // 用户名（在联想云上创建）
    password: '您的密码',                        // 密码
    timeout: 30000,                             // 连接超时（毫秒）
    autoDetect: true                            // 自动检测设备IP
};

/* 
🏠 联想个人云设置步骤：

1. 【启用WebDAV服务】
   - 打开联想个人云管理界面
   - 进入"应用中心"或"服务"
   - 启用"WebDAV"服务
   - 设置端口为5005（默认）

2. 【创建用户账号】
   - 进入"用户管理"
   - 添加新用户：planSync
   - 设置密码
   - 分配读写权限

3. 【获取设备IP】
   - 在管理界面查看"系统信息"
   - 或在路由器中查看连接设备
   - 通常格式：192.168.1.x 或 192.168.0.x

4. 【自动检测】
   - 如果不知道确切IP，系统会自动检测
   - 常见地址：192.168.1.100, 192.168.0.100 等

💡 相比GitHub的优势：
- ✅ 无需Token，只要用户名密码
- ✅ 本地网络，同步更快
- ✅ 数据完全私有，无需担心隐私
- ✅ 设置简单，三个信息即可
- ✅ 支持自动设备发现
*/
